# Apple Push Notifications (APNs) Configuration
# Get credentials from: https://developer.apple.com/documentation/usernotifications/establishing_a_token-based_connection_to_apns

# Required: Apple Developer Team ID (10 characters)
APNS_TEAM_ID=

# Required: APNs Auth Key ID (10 characters)
# Create in Apple Developer Portal: Certificates, Identifiers & Profiles → Keys → APNs
APNS_KEY_ID=

# Required: Bundle ID of your app (e.g., "com.example.myapp")
# This becomes the 'apns-topic' header
APNS_BUNDLE_ID=

# Required: Private Key (p8 format - full content including BEGIN/END lines)
# Download when creating the APNs key (can only be downloaded once!)
APNS_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
YOUR_KEY_CONTENT_HERE
-----END EC PRIVATE KEY-----"

# Alternative: Path to private key file
APNS_PRIVATE_KEY_PATH=/path/to/your/AuthKey.p8

# Required: Sandbox mode (true for development, false for production)
APNS_SANDBOX=true

# Optional: Base URL (defaults based on sandbox setting)
# Sandbox: https://api.sandbox.push.apple.com
# Production: https://api.push.apple.com
# APNS_BASE_URL=https://api.sandbox.push.apple.com

# Optional: Token TTL in seconds (default: 3600 = 60 minutes)
# Note: APNs JWTs can be reused for up to 1 hour
# APNS_TOKEN_TTL_SECONDS=3600

# Optional: Connection pool size (default: 10)
# APNS_POOL_SIZE=10

# Optional: Req options for HTTP client (JSON format)
# APNS_REQ_OPTIONS={"timeout": 30000, "pool_timeout": 5000}

# ------------------------------------------------------------------------------
# Testing with Real Devices
# ------------------------------------------------------------------------------

# Device Token for testing (64-character hex string)
# Get this from your iOS app: UIApplication.shared.delegate?.application?
#   .didRegisterForRemoteNotificationsWithDeviceToken
APNS_TEST_DEVICE_TOKEN=

# Test notification settings
APNS_TEST_ALERT_TITLE=Test Notification
APNS_TEST_ALERT_BODY=Hello from Elixir APNs!
